# MongoDB Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Database Name (default: hydro_ai_stats)
MONGODB_DB=hydro_ai_stats

# ─── Plugin runtime (HydroOJ server) ───────────────────────────────
# 32-character key used to encrypt stored API keys (see README)
# ENCRYPTION_KEY=your-32-character-secret-key!!!

# Update channel for the in-app "one-click / overwrite update":
#   stable (default) — only updates to official releases (git tag vX.Y.Z).
#                      Use this on production servers used by real users.
#   edge             — tracks the latest main branch code. Only set this on
#                      YOUR OWN test server so you can push to main and pull
#                      it instantly. Do NOT set this on users' servers.
# AI_HELPER_UPDATE_CHANNEL=stable
